      "question_id": "deployment.cicd.platform",
      "title": "CI/CD 平台",
      "description": "持續整合與持續部署使用的平台",
      "question_type": "single_select",
      "required": true,
      "owner_role": ["devops"],
      "quality_impact": "critical",
      "options": [
        { "value": "github_actions", "label": "GitHub Actions" },
        { "value": "azure_devops", "label": "Azure DevOps Pipelines" },
        { "value": "gitlab_ci", "label": "GitLab CI/CD" },
        { "value": "jenkins", "label": "Jenkins" },
        { "value": "circle_ci", "label": "CircleCI" },
        { "value": "none", "label": "無 CI/CD", "triggers": ["deployment.cicd.none_reason"] }
      ],
      "output_mapping": [
        { "target": "tech_stack", "path": "devops.cicd_platform" },
        { "target": "ai_context", "path": "devops.cicd" }
      ],
      "ai_risk_note": "CI/CD 設定影響 AI 產出的 workflow 檔案格式與部署腳本",
      "version": "1.0.0"
    },
    {
      "question_id": "deployment.cicd.none_reason",
