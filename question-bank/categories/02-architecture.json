      "version": "1.0.0"
    },
    {
      "question_id": "architecture.nfr.scalability",
      "title": "擴展性需求",
      "description": "系統預期的負載與擴展需求",
      "question_type": "single_select",
      "required": true,
      "owner_role": ["architect"],
      "quality_impact": "medium",
      "options": [
        { "value": "single_instance", "label": "單一實例，無擴展需求" },
        { "value": "vertical", "label": "垂直擴展（加大規格）" },
        { "value": "horizontal", "label": "水平擴展（多實例）" },
